LOCAL_CLIP_ROUTER_TOKEN=change-me-local-token
CLIP_ROUTER_ALLOWED_EXTENSION_ID=*
CLIP_ROUTER_PORT=18791

# Generic LLM config. Works with OpenAI-compatible chat/completions providers.
CLIP_ROUTER_LLM_API_TYPE=openai-chat
CLIP_ROUTER_LLM_BASE_URL=https://api.deepseek.com
CLIP_ROUTER_LLM_MODEL=deepseek-v4-flash
CLIP_ROUTER_LLM_API_KEY=change-me
